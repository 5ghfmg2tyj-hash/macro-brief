{
  "name": "macro-brief",
  "version": "1.2.5",
  "description": "Weekly macro allocation tracker — native macOS app",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dist":  "electron-builder --mac",
    "test":  "jest"
  },
  "devDependencies": {
    "electron":         "^35.0.0",
    "electron-builder": "^25.0.0",
    "jest":             "^29.7.0",
    "jsdom":            "^25.0.0"
  },
  "jest": {
    "testEnvironment": "node"
  },
  "build": {
    "appId":       "com.macro-brief.app",
    "productName": "Macro Brief",
    "mac": {
      "target":   [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "icon":     "electron/icon.icns",
      "category": "public.app-category.finance"
    },
    "files": [
      "electron/**/*",
      "docs/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
